# Copy this file to examples/.env and fill your real credentials.

# OpenAI-compatible LLM endpoint
OPENAI_API_KEY=your_openai_api_key
OPENAI_BASE_URL=https://api.siliconflow.cn/v1
OPENAI_MODEL=Qwen/Qwen3-235B-A22B-Instruct-2507

# Milvus / Zilliz
MILVUS_URI=https://in03-xxxx.serverless.aws-eu-central-1.cloud.zilliz.com
MILVUS_TOKEN=your_milvus_token

# API reranker (OpenAI-compatible /v1/rerank style)
RERANK_API_BASE=https://api.siliconflow.cn/v1/rerank
RERANK_API_KEY=your_rerank_api_key
RERANK_MODEL=Qwen/Qwen3-Reranker-4B

# Embedding
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=Qwen/Qwen3-Embedding-4B
EMBEDDING_DIMENSION=1536
EMBEDDING_BASE_URL=https://api.siliconflow.cn/v1
